# Which tools to suppress (comma-separated)
PIUF_SUPPRESSED_TOOLS=read,write

# Max preview lines shown before truncation
PIUF_PREVIEW_LINES=3

# Max chars per preview line
PIUF_PREVIEW_LINE_MAX_CHARS=120

# Skip suppression when output is under this many lines
PIUF_MIN_LINES=4

# Skip suppression when output is under this many chars
PIUF_MIN_CHARS=500

# Directory for temp files storing full content
# PIUF_TEMP_DIR=/tmp/pi-hide

# Enable debug logging
PIUF_DEBUG=false